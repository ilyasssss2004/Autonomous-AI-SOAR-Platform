<!-- 
  Wazuh Custom Ruleset: Autonomous SOC 
  Location: /var/ossec/etc/rules/local_rules.xml
  Logic: Detection for SSH Brute Force and Alert Tuning 
-->

<group name="authentication_failed,">

  <!-- SSH Brute Force Detection -->
  <rule id="100050" level="10" frequency="4" timeframe="120">
    <if_matched_sid>5760</if_matched_sid>
    <same_source_ip />
    <description>SOC Alert: Multiple Failed SSH Logins Detected (Potential Brute Force).</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_failed,</group>
    <ignore>120</ignore>
  </rule>

  <!-- Noise Reduction: Silencing redundant authentication attempt logs -->
  <rule id="5758" level="0" overwrite="yes">
    <match>^error: maximum authentication attempts exceeded</match>
    <description>Tuning: Silenced redundant SSH maximum attempt errors.</description>
  </rule>

  <rule id="2502" level="0" overwrite="yes">
    <if_sid>2501</if_sid>
    <match>missed the password</match>
    <description>Tuning: Silenced redundant syslog password miss alerts.</description>
  </rule>

</group>
